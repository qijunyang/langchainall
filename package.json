{
  "name": "langchainall",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LangChain.js + TypeScript demo (local Ollama) growing into an MCP-extended agent",
  "scripts": {
    "hello": "tsx src/01-hello.ts",
    "chain": "tsx src/02-chain.ts",
    "agent": "tsx src/03-agent.ts",
    "mcp": "tsx src/04-mcp-agent.ts",
    "mcp:server": "tsx src/mcps/demo-server.ts",
    "chat": "tsx src/05-chat.ts",
    "rag:ingest": "tsx src/06-rag-ingest.ts",
    "ollama:up": "docker compose --profile dev up -d",
    "ollama:down": "docker compose --profile dev down",
    "setup:model": "docker compose exec ollama ollama pull qwen2.5"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.4.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.3",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/ollama": "^1.2.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "langchain": "^1.4.4",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  }
}
